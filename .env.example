# Copy to .env and fill in real values. Do not commit .env.
#
# Rules: each setting is KEY=value on its own line, or a full-line comment starting
# with # in column 1. No leading spaces before keys. No uncommented shell commands.
#
# --- Required for MCP data collection ---
# TE_TOKEN=your-thousandeyes-mcp-bearer-token
#
# --- Optional dashboard login ---
# Set both username and password to require sign-in (except GET /api/health).
# Generate secrets (run in terminal, paste output into .env):
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# python -c "import secrets; print(secrets.token_hex(24))"
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=
# SECRET_KEY=
# Optional alias for SECRET_KEY:
# FLASK_SECRET_KEY=
# SESSION_HOURS=8
# Set the next line to true when the site is HTTPS-only:
# SESSION_COOKIE_SECURE=true
#
# --- Optional app tuning ---
# REFRESH_MINUTES=15
# MCP_MAX_RPM=240
# MCP_BATCH_SIZE=15
# MCP_INTER_BATCH_DELAY_SEC=1.0
# MCP_SYNTH_CONCURRENCY=1
# MCP_URL=https://api.thousandeyes.com/mcp
# ConnectTimeout = TCP/TLS to MCP_URL too slow (firewall, proxy, inspected TLS). Defaults: 90s connect, 6 attempts.
# MCP_CONNECT_TIMEOUT_SEC=180
# MCP_READ_TIMEOUT_SEC=300
# MCP_RETRIES=8
# Longer pauses between retries on ConnectTimeout / ConnectError / ReadTimeout only:
# MCP_TRANSPORT_BACKOFF_BASE_SEC=8
# MCP_TRANSPORT_BACKOFF_MAX_SEC=120
# Corporate proxy (httpx reads these automatically): HTTPS_PROXY=http://proxy:8080
# LOG_LEVEL=ERROR
# At INFO or DEBUG, Werkzeug logs each HTTP request (access log). Default ERROR keeps logs quiet.
#
# Business Services (NOC): optional JSON or file path (prefer file for long JSON).
# BUSINESS_SERVICES_CONFIG_FILE=./config/business_services.json
#
# --- Optional KPI history (SQLite) for trending without MCP replay ---
# Default file: ./data/kpi_history.sqlite (created automatically).
# KPI_DB_PATH=C:/path/to/kpi_history.sqlite
# KPI_HISTORY_DISABLED=false
#
# Hourly rollup retention: per-test + scalar KPIs stored each hour (default 14 days)
# KPI_HOURLY_RETENTION_DAYS=14
# Daily aggregate retention: computed from hourly data (default 60 days)
# KPI_DAILY_RETENTION_DAYS=60
# Legacy setting (still read for old kpi_point table pruning):
# KPI_HISTORY_RETENTION_DAYS=90
#
# --- Startup: quick first paint (then 1h hourly + 24h cache in background) ---
# Fetches INITIAL_BOOTSTRAP_WINDOW first so the UI can load sooner at scale;
# 1h hourly bucket + 24h cache fallback continue in a background thread.
# INITIAL_BOOTSTRAP_WINDOW=1h
# INITIAL_BOOTSTRAP_DISABLED=true
