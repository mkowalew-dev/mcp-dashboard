# Copy to .env and fill in real values. Do not commit .env.
#
# --- Required for MCP data collection ---
# TE_TOKEN=your-thousandeyes-mcp-bearer-token
#
# --- Optional dashboard login ---
# Set both username and password to require sign-in for pages and APIs (except GET /api/health).
# Use different random values for DASHBOARD_PASSWORD and SECRET_KEY. Generate examples:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   python -c "import secrets; print(secrets.token_hex(24))"
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=
# SECRET_KEY=
# FLASK_SECRET_KEY=   # optional alias for SECRET_KEY if you prefer that name
# SESSION_HOURS=8
# SESSION_COOKIE_SECURE=true   # set true when serving only over HTTPS
#
# --- Optional app tuning ---
# REFRESH_MINUTES=15
# MCP_MAX_RPM=240
# MCP_BATCH_SIZE=15
# MCP_INTER_BATCH_DELAY_SEC=1.0
# MCP_SYNTH_CONCURRENCY=1
# MCP_URL=https://api.thousandeyes.com/mcp
# LOG_LEVEL=ERROR   # ERROR (default), WARNING, INFO, DEBUG, or TRACE
#
# Business Services (NOC): optional JSON or file path
# BUSINESS_SERVICES_CONFIG='{"type_rules":{"Infrastructure":["agent-to-agent","bgp"],"Voice":["voice","sip-server"]},"services":[{"name":"Collaboration - Microsoft","icon":"\uD83D\uDCE7","patterns":["MSTeams"]},...]}'
# BUSINESS_SERVICES_CONFIG_FILE=./config/business_services.json
