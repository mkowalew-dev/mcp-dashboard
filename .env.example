# Copy to .env and fill in real values. Do not commit .env.
# TE_TOKEN=your-thousandeyes-mcp-bearer-token
# REFRESH_MINUTES=15
# Optional tuning (API limit is 240 rpm per client; keep defaults to stay under it):
# MCP_MAX_RPM=240
# MCP_BATCH_SIZE=15
# MCP_INTER_BATCH_DELAY_SEC=1.0
# MCP_SYNTH_CONCURRENCY=1
# MCP_URL=https://api.thousandeyes.com/mcp
# Metrics filter (fewer tests = less load and fewer 429s): exclude by test type and by business service grouping (app-defined from test names, same as UI)
# METRICS_EXCLUDED_TEST_TYPES=bgp,ftp-server,sftp,agent-to-agent
# METRICS_EXCLUDED_BUSINESS_SERVICES=Other Services|Demo & Monitoring|Facebook & Social|Data Center Management
